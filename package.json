{
  "name": "handler",
  "version": "3.0.0",
  "description": "A simple handler for a discord bot",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "biome format ./src --write",
    "lint": "biome lint ./src",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{ts,js}": [
      "node scripts/header.js --stage",
      "biome format --write",
      "biome lint --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@types/node": "^26.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "discord-api-types": "^0.38.49",
    "discord-hybrid-sharding": "^3.0.1",
    "discord.js": "^14.26.4",
    "zod": "^4.4.3"
  }
}
